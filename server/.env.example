PORT=3000

# Danh sách Admin khởi tạo (phân cách bằng dấu phẩy)
# Chỉ dùng lần đầu khi file data/config.json chưa tồn tại
ADMIN_EMAILS=admin@company.com,manager@company.com

# Tên HTTP header chứa email người dùng từ hệ thống (mặc định: x-user-email)
# Dashboard cần gửi header này khi proxy request tới wiki
# USER_EMAIL_HEADER=x-user-email

# API key cho tính năng Hỏi đáp AI (tạo miễn phí tại https://aistudio.google.com/apikey)
# GEMINI_API_KEY=AIza...
# Model dùng cho hỏi đáp (mặc định: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# AI đọc link nội bộ cần đăng nhập: ngoài host của chính wiki (tự nhận),
# liệt kê thêm host được phép gửi kèm cookie đăng nhập khi tải trang trong link
# LINK_AUTH_HOSTS=dashboard.example.com,103.140.249.232
